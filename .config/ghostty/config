# Theme
theme="Xcode Light"
macos-icon=retro
window-padding-x=5
window-padding-y=5
cursor-style=bar

# Common font settings
font-size=14

# My settings for JetBrains Mono
#font-family="JetBrains Mono"

# My settings for IBM Plex Mono
font-family="IBM Plex Mono"
#font-style=Medium

# Enable option+keys on macOS
macos-option-as-alt=true

# Mmm pretty
background-opacity=0.95
background-blur-radius = 20

# Quick terminal
keybind = global:cmd+grave_accent=toggle_quick_terminal

# When SSHing into servers, automatically set ghostty terminal mode
shell-integration-features = ssh-terminfo,ssh-env
